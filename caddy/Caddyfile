:80 {
    handle_path /flutter/* {
        root * /srv/flutter
        try_files {path} {path}/ /index.html
        file_server
    }

    handle /webchat* {
        reverse_proxy nanobot:8765
    }

    handle /ws* {
        reverse_proxy nanobot:8765
    }

    handle /docs* {
        reverse_proxy backend:8000
    }

    handle /openapi.json {
        reverse_proxy backend:8000
    }

    handle /items* {
        reverse_proxy backend:8000
    }

    handle /interactions* {
        reverse_proxy backend:8000
    }

    handle /learners* {
        reverse_proxy backend:8000
    }

    handle /pipeline* {
        reverse_proxy backend:8000
    }

    handle /analytics* {
        reverse_proxy backend:8000
    }

    handle /utils/pgadmin* {
        reverse_proxy pgadmin:80
    }

    handle {
        root * /srv/react
        try_files {path} /index.html
        file_server
    }
}

# Flutter web chat uses the nanobot websocket route /ws/chat.
